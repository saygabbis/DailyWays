# Supabase - copie para .env.local e preencha com os valores do seu projeto em https://supabase.com/dashboard
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key
#
# URL pública do app (produção). Ex.: http://SEU_IP:5174 ou https://seu-dominio.com
# Em dev, você pode omitir e o app usa window.location.origin (ex.: http://localhost:5173)
VITE_PUBLIC_SITE_URL=

# Collab: auto = mesmo host (dev: proxy Vite; VPS: nginx /socket.io → :2529)
VITE_COLLAB_SERVER_URL=auto

# --- collab-server (server/collab-server/.env) — deve estar rodando na VPS (pm2/systemd) ---
# SUPABASE_URL=https://seu-projeto.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key
# PORT=2529
# CORS_ORIGIN=https://dailyways.saygabbis.cloud,http://localhost:5174
# NODE_ENV=production
# COLLAB_FLUSH_MS=3000
