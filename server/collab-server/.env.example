SUPABASE_URL=https://seu-projeto.supabase.co
# Chave completa (~200+ chars). Se truncar no editor, auth/persistência falham.
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key
# Obrigatória para auth/RLS no collab (copie VITE_SUPABASE_ANON_KEY do .env.local)
SUPABASE_ANON_KEY=
PORT=2529
# Local: use development (production no .env bloqueava IP 192.168.x no CORS)
NODE_ENV=development
# Inclua o domínio HTTPS de produção — sem isso o browser recebe 400 no POST do socket.io
# Produção: apenas origens listadas (LAN privada NÃO é aceita em NODE_ENV=production)
CORS_ORIGIN=http://localhost:5174,https://dailyways.saygabbis.cloud
# DEV prank: desligado em produção salvo COLLAB_DEV_PRANK=1. Allowlist por UUID:
# COLLAB_DEV_USER_IDS=uuid-do-dev,uuid-outro
# COLLAB_DEV_PRANK=0
# Rate limits (opcional):
# COLLAB_MAX_OPS_PER_SEC=120
# COLLAB_MAX_POSITION_OPS_PER_SEC=300
# COLLAB_MAX_OPS_PER_IP_PER_SEC=240
# COLLAB_MAX_CONNECTIONS_PER_USER=10
# COLLAB_MAX_AUTH_FAILS_PER_IP_PER_MIN=60
# Flush ao DB: 600ms default; 0 = imediato após cada op estrutural/completed
COLLAB_FLUSH_MS=600
